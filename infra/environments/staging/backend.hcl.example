# Copy to backend.hcl (gitignored) or pass via: terraform init -backend-config=backend.hcl
#
# Use a dedicated S3 bucket (and optional DynamoDB lock table) in your AWS account.
# dynamodb_table = "codecanary-tfstate-lock"
bucket = "codecanary-tfstate"
key    = "staging/terraform.tfstate"
region = "ap-northeast-2"
