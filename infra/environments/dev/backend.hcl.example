# Copy to backend.hcl (gitignored) or pass via: terraform init -backend-config=backend.hcl
#
# Real AWS S3 backend. Create the bucket once (versioning recommended).
# Optional state locking: add dynamodb_table = "codecanary-tfstate-lock"
bucket = "codecanary-tfstate"
key    = "dev/terraform.tfstate"
region = "ap-northeast-2"
