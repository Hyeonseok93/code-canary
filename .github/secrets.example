# GitHub → repo Settings → Secrets and variables → Actions → New repository secret
#
# --- fakecloud (dev, self-hosted runner on WSL) ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=ap-northeast-2
AWS_ENDPOINT=http://localhost:4566
ECR_REGISTRY=localhost:4566
#
# Frontend build-time paths (public in bundle; optional — defaults match local/.env)
VITE_ADMIN_BASE=/roost
VITE_ADMIN_HATCH=hatch
VITE_ADMIN_FORAGE=forage
#
# --- real AWS (later) ---
# AWS_ACCESS_KEY_ID=<IAM access key>   # or use OIDC and drop static keys
# AWS_SECRET_ACCESS_KEY=<IAM secret>
# AWS_REGION=ap-northeast-2
# AWS_ENDPOINT=                        # omit or leave empty — uses real AWS
# ECR_REGISTRY=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com
