# =============================================================================
# Code Canary — environment template
# Copy to .env and fill secrets before: local/docker-up.cmd or local/docker-up.sh
#   cp .env.example .env
# =============================================================================

# --- Operator console (Vite build — embedded in frontend bundle) ---
VITE_ADMIN_BASE=/roost
VITE_ADMIN_HATCH=hatch
VITE_ADMIN_FORAGE=forage
VITE_DEV_API_TARGET=http://localhost:8080

# --- Database ---
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_NAME=code_canary
DB_PASSWORD=CHANGE_ME

# --- JWT / operator auth ---
# Min 32 UTF-8 characters (JwtTokenProvider requirement)
JWT_SECRET=local-dev-jwt-secret-min-32-chars!!
JWT_EXPIRATION_MS=1800000
# false for local HTTP (localhost:80); set true when serving over HTTPS
JWT_COOKIE_SECURE=false
JWT_REVOCATION_PRUNE_INTERVAL_MS=3600000

# --- Login protection ---
LOGIN_MAX_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
LOGIN_MAX_REQUESTS_PER_MINUTE=10

# --- Redis (rate limiting; required for Docker — synced to local/.docker-secrets by prepare-docker-secrets.sh) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# --- Public analytics API ---
ANALYTICS_MAX_GENERAL_REQUESTS_PER_MINUTE=60
ANALYTICS_MAX_EXPLORER_REQUESTS_PER_MINUTE=30
ANALYTICS_MAX_DETAIL_REQUESTS_PER_MINUTE=30
ANALYTICS_CACHE_MAX_AGE_SECONDS=120

# --- Explorer API ---
EXPLORER_MAX_PAGE_SIZE=100
EXPLORER_MAX_SEARCH_LENGTH=200
EXPLORER_MAX_FILTER_TOKENS=20
EXPLORER_MAX_FILTER_TOKEN_LENGTH=100

# --- Backend server ---
SERVER_PORT=8080
# Docker frontend-net subnet (must match local/docker-compose.yml); empty = never trust X-Real-IP
TRUSTED_PROXY_CIDRS=172.28.0.0/24
PIPELINE_DATA_ROOT=/data

# --- Worker / pipeline collectors ---
# Optional: request from https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
NVD_API_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
OSV_API_URL=https://osv-vulnerabilities.storage.googleapis.com/all.zip
WORKER_POLL_SECONDS=5
WORKER_HEARTBEAT_SECONDS=60
WORKER_JOB_STALE_MINUTES=10
PIPELINE_JOB_STALE_MINUTES=10
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Docker host port bindings (127.0.0.1 only) ---
DB_HOST_PORT=5433
FRONTEND_HOST_PORT=80

# --- Nginx (Docker internal upstream — see frontend/nginx.conf) ---
# NGINX_BACKEND_UPSTREAM=backend:8080
